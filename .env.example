# =============================================================================
# OpenClaw + Ollama — Environment Variables (EXAMPLE)
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Host path to OpenClaw config directory
OPENCLAW_CONFIG_DIR=/home/YOUR_USERNAME/.openclaw

# Host path to OpenClaw agent workspace
OPENCLAW_WORKSPACE_DIR=/home/YOUR_USERNAME/.openclaw/workspace

# Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Bridge port (default: 18790)
OPENCLAW_BRIDGE_PORT=18790

# Network bind mode: "lan" (0.0.0.0) or "loopback" (127.0.0.1)
OPENCLAW_GATEWAY_BIND=lan

# Gateway auth token (auto-generated by docker-setup.sh)
OPENCLAW_GATEWAY_TOKEN=YOUR_TOKEN_HERE

# Docker image to use (openclaw:local for local build, or ghcr.io/openclaw/openclaw:latest)
OPENCLAW_IMAGE=openclaw:local

# Extra bind mounts (comma-separated, optional)
OPENCLAW_EXTRA_MOUNTS=

# Named volume for /home/node (optional)
OPENCLAW_HOME_VOLUME=

# Extra apt packages to install during build (optional)
OPENCLAW_DOCKER_APT_PACKAGES=

# OpenClaw extensions to pre-install (space-separated, optional)
OPENCLAW_EXTENSIONS=

# Enable sandbox isolation (1/true/yes/on to enable)
OPENCLAW_SANDBOX=

# Docker socket path override
OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock

# Docker socket GID for sandbox group_add
DOCKER_GID=

# Install Docker CLI in image (for sandbox)
OPENCLAW_INSTALL_DOCKER_CLI=

# Allow insecure private-network ws:// targets
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
